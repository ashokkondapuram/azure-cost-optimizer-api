# Frontend environment (Create React App)
#
# Local dev (bare metal):
#   cp frontend/.env.example frontend/.env
#
# Docker dev uses compose env vars — see docker/.env.example

# Production: absolute API URL when not served from same origin
# REACT_APP_API_URL=https://<your-azure-webapp-url>

# Axios default timeout for /api requests (milliseconds)
REACT_APP_API_TIMEOUT_MS=120000

# Client inactivity sign-out (milliseconds; should match SESSION_IDLE_MINUTES on backend)
REACT_APP_SESSION_IDLE_MS=60000
