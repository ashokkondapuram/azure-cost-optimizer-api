  "rule_configurations": {
    "DISK_NEW_GRACE_PERIOD": {
      "grace_period_days": 7,
      "description": "Skip optimization for disks created less than 7 days ago - workload may not be stable"
    },
    "DISK_ULTRA_DOWNGRADE_PREMIUM": {
      "iops_utilization_threshold_pct": 50,
      "throughput_utilization_threshold_pct": 50,
      "min_monthly_savings_usd": 50,
      "description": "Recommend downgrading UltraSSD to Premium when IOPS/throughput utilization < 50%"
    },
    "DISK_ULTRA_DOWNGRADE_SSD": {
      "iops_utilization_threshold_pct": 30,
      "throughput_utilization_threshold_pct": 30,
      "min_monthly_savings_usd": 100,
      "description": "Recommend downgrading UltraSSD to StandardSSD when IOPS/throughput utilization < 30%"
    },
    "DISK_PREMIUM_DOWNGRADE_HDD": {
      "iops_utilization_threshold_pct": 15,
      "throughput_utilization_threshold_pct": 15,
      "min_monthly_savings_usd": 10,
      "description": "Recommend downgrading Premium to Standard HDD for unattached disks with utilization < 15%"
    },
    "DISK_SSD_DOWNGRADE_HDD": {
      "iops_utilization_threshold_pct": 20,
      "throughput_utilization_threshold_pct": 20,
      "min_monthly_savings_usd": 2,
      "description": "Recommend downgrading StandardSSD to Standard HDD when IOPS/throughput utilization < 20%"
    }
  },
  "analysis_rules": {
    "DISK_UNATTACHED": {
      "name": "Unattached Managed Disk",
      "description": "Managed disk not attached to any VM.",
      "category": "COMPUTE",
      "severity": "HIGH",
      "engine": "standard",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": [],
      "thresholds": {}
    },
    "DISK_OVERSIZE": {
      "name": "Oversized Disk (Premium to Standard)",
      "description": "Premium SSD on idle workload — downgrade tier.",
      "category": "COMPUTE",
      "severity": "LOW",
      "engine": "standard",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_bps", "disk_write_bps"],
      "thresholds": {}
    },
    "DISK_UNUSED_EXTENDED": {
      "name": "Extended Unused Disk Detection",
      "description": "Unattached beyond threshold or attached with idle I/O.",
      "category": "COMPUTE",
      "severity": "HIGH",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_bps", "disk_write_bps"],
      "thresholds": {
        "max_unattached_disk_days": 14,
        "disk_io_idle_bps": 1024.0,
        "disk_idle_min_size_gb": 128,
        "disk_iops_block_downgrade_pct": 20.0
      }
    },
    "DISK_OVERSIZE_EXTENDED": {
      "name": "Oversized Premium Disk",
      "description": "Premium SSD with near-zero I/O — downgrade to Standard SSD.",
      "category": "COMPUTE",
      "severity": "LOW",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_bps", "disk_write_bps"],
      "thresholds": {
        "disk_io_idle_bps": 1024.0,
        "disk_iops_block_downgrade_pct": 20.0
      }
    },
    "DISK_UNDERPROVISIONED": {
      "name": "Under-Provisioned Managed Disk",
      "description": "IOPS or throughput near provisioned cap.",
      "category": "RELIABILITY",
      "severity": "MEDIUM",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_iops", "disk_write_iops"],
      "thresholds": {
        "disk_iops_high_util_pct": 80.0
      }
    },
    "DISK_CAPACITY_RIGHTSIZE_EXTENDED": {
      "name": "Managed Disk Capacity Right-Sizing",
      "description": "Provisioned size exceeds measured utilization.",
      "category": "COMPUTE",
      "severity": "LOW",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "enabled": false,
      "metrics_required": [],
      "metrics_unavailable_reason": "Used Size Percentage is not published for microsoft.compute/disks. Use guest OS disk space metrics (VM Insights LogicalDisk/FreeSpacePercentage) on the attached VM.",
      "documentation": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-compute-disks-metrics",
      "thresholds": {
        "disk_capacity_used_pct_max": 30.0,
        "min_monthly_savings_usd": 3.0
      }
    },
    "DISK_QUEUE_DEPTH_EXTENDED": {
      "name": "Managed Disk Queue Depth Contention",
      "description": "Queue depth indicates I/O contention.",
      "category": "RELIABILITY",
      "severity": "HIGH",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "enabled": false,
      "metrics_required": [],
      "metrics_unavailable_reason": "Disk Queue Depth is not published for microsoft.compute/disks. Use OS Disk Queue Depth or Data Disk Queue Depth on microsoft.compute/virtualmachines.",
      "documentation": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-compute-virtualmachines-metrics",
      "thresholds": {
        "disk_queue_depth_contention": 10.0
      }
    },
    "DISK_NEW_GRACE_PERIOD": {
      "name": "New Disk Grace Period",
      "description": "Skip recommendations for disks younger than grace window.",
      "category": "COMPUTE",
      "severity": "INFO",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "thresholds": {
        "new_disk_grace_period_days": 7
      }
    },
    "DISK_ULTRA_DOWNGRADE_PREMIUM": {
      "name": "UltraSSD to Premium Downgrade",
      "description": "UltraSSD utilization below 50% — move to Premium SSD.",
      "category": "COMPUTE",
      "severity": "MEDIUM",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_iops", "disk_write_iops"],
      "min_monthly_savings_usd": 50
    },
    "DISK_ULTRA_DOWNGRADE_SSD": {
      "name": "UltraSSD to Standard SSD Downgrade",
      "description": "UltraSSD utilization below 30% — move to Standard SSD.",
      "category": "COMPUTE",
      "severity": "MEDIUM",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_iops", "disk_write_iops"],
      "min_monthly_savings_usd": 100
    },
    "DISK_PREMIUM_DOWNGRADE_HDD": {
      "name": "Premium to Standard HDD Downgrade",
      "description": "Premium disk with very low utilization.",
      "category": "COMPUTE",
      "severity": "LOW",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_iops", "disk_write_iops"],
      "min_monthly_savings_usd": 10
    },
    "DISK_SSD_DOWNGRADE_HDD": {
      "name": "Standard SSD to HDD Downgrade",
      "description": "Standard SSD with very low I/O.",
      "category": "COMPUTE",
      "severity": "LOW",
      "engine": "extended",
      "savings_basis": "azure_billed_mtd",
      "metrics_required": ["disk_read_iops", "disk_write_iops"],
      "min_monthly_savings_usd": 2
    }
  },
  "cost_policy": {
    "source": "azure_cost_management",
    "field": "PreTaxCost",
    "description": "Analysis uses MTD billed cost synced from Azure Cost Management — not catalog estimates.",
