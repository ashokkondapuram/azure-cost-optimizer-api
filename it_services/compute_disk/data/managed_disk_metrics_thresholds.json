  "downgrade_rules": {
    "UltraSSD_to_Premium": {
      "source_tier": "ultra",
      "target_tier": "premium_ssd",
      "iops_utilization_max": 50,
      "throughput_utilization_max": 50,
      "min_months_data": 1,
      "min_monthly_savings_usd": 50,
      "description": "Downgrade UltraSSD to Premium when IOPS/throughput utilization is consistently <50%"
    },
    "UltraSSD_to_StandardSSD": {
      "source_tier": "ultra",
      "target_tier": "standard_ssd",
      "iops_utilization_max": 30,
      "throughput_utilization_max": 30,
      "min_months_data": 1,
      "min_monthly_savings_usd": 100,
      "description": "Direct downgrade from UltraSSD to StandardSSD when utilization is very low"
    },
    "Premium_to_StandardSSD": {
      "source_tier": "premium_ssd",
      "target_tier": "standard_ssd",
      "iops_utilization_max": 30,
      "throughput_utilization_max": 30,
      "min_months_data": 1,
      "min_monthly_savings_usd": 5,
      "description": "Downgrade Premium to StandardSSD when IOPS/throughput utilization is consistently <30% (aggressive)"
    },
    "StandardSSD_to_Standard": {
      "source_tier": "standard_ssd",
      "target_tier": "hdd",
      "iops_utilization_max": 20,
      "throughput_utilization_max": 20,
      "min_months_data": 1,
      "min_monthly_savings_usd": 2,
      "description": "Downgrade StandardSSD to Standard HDD when IOPS/throughput utilization is consistently <20%"
    },
    "Premium_to_Standard": {
      "source_tier": "premium_ssd",
      "target_tier": "hdd",
      "iops_utilization_max": 15,
      "throughput_utilization_max": 15,
      "min_months_data": 1,
      "min_monthly_savings_usd": 10,
      "description": "Direct downgrade from Premium to Standard HDD when utilization is very low"
    }
  },
