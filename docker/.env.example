# CostOptimizeRecommender — Docker Desktop local development
# Copy to docker/.env and adjust. Never commit docker/.env (real secrets).
#
#   cp docker/.env.example docker/.env
#   # or: ./docker/build.sh up  (auto-creates docker/.env and docker/desktop/.env)
#
# Docker Desktop UI: compose auto-loads docker/desktop/.env (kept in sync by build.sh).
#
# Required before ./docker/build.sh up:
#   POSTGRES_PASSWORD  (or DB_PASSWORD as alias — see build.sh)

# ── Compose / image targets ─────────────────────────────────────────────────
COMPOSE_PROFILES=dev
# dev  = platform microservices + React dev server (default)
# prod = nginx frontend + platform microservices + gateway
# prod = production images (nginx frontend, optimized backend)
# microservices = split cost + analysis + gateway (combine with dev or prod)
# Quick microservices: ./docker/build.sh up-microservices

BACKEND_TARGET=dev
FRONTEND_TARGET=dev

# ── PostgreSQL (required) ───────────────────────────────────────────────────
POSTGRES_USER=costoptimizer
POSTGRES_PASSWORD=changeme
POSTGRES_DB=costoptimizer
POSTGRES_PORT=5432
# Server connection budget — 6 microservices × (pool 8 + overflow 12) ≈ 120 client slots
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_WORK_MEM=4MB

# DB_PASSWORD is an optional alias; build.sh copies it to POSTGRES_PASSWORD when unset.
# DB_PASSWORD=changeme

# Compose assembles backend DATABASE_URL from POSTGRES_* above — keep the password in sync.
# Host connection (psql, DBeaver, etc. from your machine):
# postgresql://costoptimizer:changeme@127.0.0.1:5432/costoptimizer?sslmode=disable

# ── Backend (FastAPI) ───────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
AUTH_ENABLED=true
REQUEST_TIMEOUT_SECONDS=60

# Dev-only credentials — change before sharing your machine
JWT_SECRET=dev-only-change-me-docker-local-32chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=viewer

CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Database pool (PostgreSQL) — per microservice process
DATABASE_POOL_SIZE=8
DATABASE_MAX_OVERFLOW=12
DATABASE_POOL_TIMEOUT_SEC=30
DATABASE_POOL_RECYCLE_SEC=1800

# Auth cache / session
AUTH_USER_CACHE_SECONDS=60
SESSION_IDLE_MINUTES=1

# Enrichment + metrics sync
ENRICHMENT_MAX_AGE_HOURS=6
COST_SYNC_INTERVAL_MINUTES=60
COST_SYNC_STARTUP_DELAY_SEC=0
METRICS_SYNC_INTERVAL_MINUTES=30
METRICS_SYNC_STARTUP_DELAY_SEC=120
METRICS_SYNC_WORKER_ENABLED=true
INVENTORY_SYNC_INTERVAL_MINUTES=15
INVENTORY_SYNC_STARTUP_DELAY_SEC=60
ANALYSIS_SYNC_INTERVAL_MINUTES=10
ANALYSIS_SYNC_STARTUP_DELAY_SEC=180

# Azure Monitor metrics fetch (deep analysis — not scheduled/sync workers)
ANALYSIS_MONITOR_METRICS_TIMESPAN=P7D
ANALYSIS_MONITOR_METRICS_LIMIT_PER_TYPE=0
ANALYSIS_MONITOR_METRICS_WORKERS=6
ANALYSIS_MONITOR_METRICS_TIMEOUT_SEC=120

# Sync + scheduled metrics worker (30s, no retry, 3 workers)
SYNC_MONITOR_METRICS_TIMEOUT_SEC=30
SYNC_MONITOR_METRICS_MAX_RETRIES=0
SYNC_MONITOR_METRICS_MAX_WORKERS=3
SYNC_MONITOR_METRICS_LIMIT_PER_TYPE=0
METRICS_SYNC_TIMEOUT_SEC=30
METRICS_SYNC_MAX_RETRIES=0
METRICS_SYNC_MAX_WORKERS=3

# Azure (optional for local — configure via Settings UI or env)
AZURE_AUTH_MODE=default
# AZURE_DEFAULT_SUBSCRIPTION_ID=<subscription-guid>
# AZURE_TENANT_ID=<tenant-guid>
# AZURE_CLIENT_ID=<client-id>
# AZURE_CLIENT_SECRET=<client-secret>

# Reduce background Azure sync noise in local Docker (recommended)
# Set SCHEDULED_OPERATIONS_ENABLED=true on platform-cost, -inventory, -metrics, -analysis
SCHEDULED_OPERATIONS_ENABLED=false
# On-demand analysis pipeline (manual sync/analyze) stays enabled
ASSESSMENT_PIPELINE_ENABLED=true
RESOURCE_DISCOVERY_WORKER_ENABLED=false
COST_EXPLORER_WORKER_ENABLED=false

# ── Frontend (React) ────────────────────────────────────────────────────────
FRONTEND_PORT=3000
GATEWAY_PORT=8080
CORE_SERVICE_PORT=8010
COST_SERVICE_PORT=8011
ANALYSIS_SERVICE_PORT=8013
METRICS_SERVICE_PORT=8014
INVENTORY_SERVICE_PORT=8012
CORE_SERVICE_PORT=8010
COMPUTE_DISK_SERVICE_PORT=8108
SECURITY_KEYVAULT_SERVICE_PORT=8141
GATEWAY_PROXY_TARGET=http://gateway:8080
CORE_SERVICE_PROXY_TARGET=http://core-service:8010
CORE_SERVICE_PROXY_TARGET=http://core-service:8010
INVENTORY_SERVICE_PROXY_TARGET=http://inventory-service:8012
COST_SERVICE_PROXY_TARGET=http://cost-service:8011
ANALYSIS_SERVICE_PROXY_TARGET=http://analysis-service:8013
METRICS_SERVICE_PROXY_TARGET=http://metrics-service:8014
# Set MICROSERVICES_MODE=1 when COMPOSE_PROFILES includes microservices
MICROSERVICES_MODE=1
MICROSERVICES_ONLY=1
# Optional: route /api/costs and /api/optimize directly (skip gateway)
MICROSERVICES_DIRECT=0

# Gateway upstream timeouts (seconds)
GATEWAY_UPSTREAM_TIMEOUT_SECONDS=120
GATEWAY_OPTIMIZE_TIMEOUT_SECONDS=300
GATEWAY_SYNC_ACCEPT_TIMEOUT_SECONDS=30

# ── Redpanda / Kafka API (microservices sync pipeline) ───────────────────────
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_PORT=9092
KAFKA_UI_PORT=8085
KAFKA_SCHEMA_REGISTRY_URL=http://redpanda:8081
KAFKA_SCHEMA_REGISTRY_PORT=18081
KAFKA_SCHEMA_REGISTRY_ENABLED=true
KAFKA_SCHEMA_VALIDATION_ENABLED=true
REDPANDA_VERSION=v25.3.1
REDPANDA_CONSOLE_VERSION=v3.8.0
REDPANDA_CONTAINER=costopt-redpanda
# Production broker overlay: docker compose -f ... -f docker/redpanda.compose.prod.yml up
KAFKA_CLIENT_ID=costoptimizer
KAFKA_CONSUMER_GROUP_PREFIX=costoptimizer
KAFKA_TOPIC_PARTITIONS=6
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_RETENTION_MS=604800000
KAFKA_TOPICS_MANIFEST=/app/data/kafka-topics.yaml
KAFKA_SCHEMAS_MANIFEST=/app/data/kafka/schemas/schemas-manifest.yaml
KAFKA_SCHEMAS_DIR=/app/data/kafka/schemas
KAFKA_DATA_PIPELINE_ENABLED=true
KAFKA_ENSURE_TOPICS_ON_STARTUP=true

# Kafka API throttling — fan out Azure calls through api.* topics with rate limits
KAFKA_API_THROTTLE_ENABLED=true
KAFKA_API_DLQ_ENABLED=true
KAFKA_API_COST_RATE_PER_SEC=2
KAFKA_API_COST_BURST=4
KAFKA_API_COST_WORKER_CONCURRENCY=3
KAFKA_API_METRICS_RATE_PER_SEC=3
KAFKA_API_METRICS_BURST=6
KAFKA_API_METRICS_WORKER_CONCURRENCY=3
KAFKA_API_INVENTORY_RATE_PER_SEC=4
KAFKA_API_INVENTORY_BURST=8
KAFKA_API_INVENTORY_WORKER_CONCURRENCY=4
KAFKA_API_AGGREGATE_TIMEOUT_SEC=900

WDS_SOCKET_HOST=127.0.0.1
CHOKIDAR_USEPOLLING=true
REACT_APP_API_TIMEOUT_MS=120000
REACT_APP_SESSION_IDLE_MS=60000

# ── Optional — cost export blob storage ─────────────────────────────────────
# COST_EXPORT_ACCOUNT_NAME=
# COST_EXPORT_ACCOUNT_KEY=
# COST_EXPORT_CONTAINER=cost

# ── Optional — Azure OpenAI ─────────────────────────────────────────────────
# OPENAI_KEY=
# OPENAI_ENDPOINT=
# OPENAI_DEPLOYMENT=gpt-4o-mini
