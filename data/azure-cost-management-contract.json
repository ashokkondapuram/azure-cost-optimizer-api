{
  "schemaVersion": "1.0.0",
  "name": "Azure Cost Management Charging Contract",
  "purpose": "Common Cost Management and Retail Prices contract used by Azure resource assessment JSON files.",
  "costManagementApi": {
    "queryUsage": {
      "method": "POST",
      "url": "https://management.azure.com/{scope}/providers/Microsoft.CostManagement/query?api-version=2025-03-01",
      "recommendedScopeOrder": [
        "/subscriptions/{subscriptionId}",
        "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}",
        "/providers/Microsoft.Billing/billingAccounts/{billingAccountId}",
        "/providers/Microsoft.Billing/billingAccounts/{billingAccountId}/billingProfiles/{billingProfileId}",
        "/providers/Microsoft.Management/managementGroups/{managementGroupId}"
      ]
    },
    "retailPrices": {
      "method": "GET",
      "url": "https://prices.azure.com/api/retail/prices?api-version=2023-01-01-preview&$filter={filter}"
    }
  },
  "requiredCostColumns": [
    "Date",
    "ResourceId",
    "ResourceType",
    "ResourceLocation",
    "ResourceGroup",
    "SubscriptionId",
    "ServiceName",
    "ServiceFamily",
    "Product",
    "Meter",
    "MeterCategory",
    "MeterSubCategory",
    "MeterRegion",
    "SkuName",
    "ChargeType",
    "PricingModel",
    "PublisherType",
    "Frequency",
    "Quantity",
    "UnitOfMeasure",
    "Cost",
    "CostUSD",
    "Currency"
  ],
  "recommendedGroupBy": [
    "ResourceId",
    "ResourceType",
    "ResourceLocation",
    "ResourceGroup",
    "ServiceName",
    "ServiceFamily",
    "Product",
    "Meter",
    "MeterCategory",
    "MeterSubCategory",
    "SkuName",
    "ChargeType",
    "PricingModel",
    "Frequency"
  ],
  "recommendedAggregations": {
    "actualCost": "sum(Cost)",
    "actualCostUsd": "sum(CostUSD)",
    "usageQuantity": "sum(Quantity)",
    "meterCount": "count_distinct(Meter)",
    "activeDays": "count_distinct(Date)"
  },
  "chargeTypes": {
    "Usage": "Consumption-based usage charge for the meter.",
    "Purchase": "Up-front purchase such as reservation, savings plan, marketplace, or commitment.",
    "Refund": "Refund or credit.",
    "UnusedReservation": "Unused reserved capacity allocation where available.",
    "UnusedSavingsPlan": "Unused savings plan allocation where available.",
    "RoundingAdjustment": "Billing rounding or adjustment."
  },
  "pricingModels": {
    "OnDemand": "Pay-as-you-go consumption.",
    "Reservation": "Reserved capacity or reserved instance pricing.",
    "SavingsPlan": "Azure savings plan pricing.",
    "Spot": "Interruptible spot pricing where applicable.",
    "Marketplace": "Marketplace image, software, or third-party charge.",
    "Commitment": "Commitment or capacity-based charge."
  },
  "costAllocationRules": [
    {
      "id": "resource_id_exact",
      "description": "Prefer exact ResourceId match for direct resource meters."
    },
    {
      "id": "child_resource_rollup",
      "description": "Roll child resources up to parent when billing appears on child IDs, such as disks under VMs, databases under SQL servers, apps under App Service plans, or Databricks managed resource group infrastructure."
    },
    {
      "id": "tag_allocation",
      "description": "Use tags such as owner, app, environment, costCenter, workload, cluster_id, job_id, or warehouse_id when ResourceId alone is not enough."
    },
    {
      "id": "meter_based_split",
      "description": "Split blended resources by Product, Meter, SkuName, ChargeType, and PricingModel when a service has compute, storage, backup, network, and request meters."
    }
  ],
  "normalizationFieldsForAnalyzers": {
    "resource_id": "ResourceId",
    "resource_type": "ResourceType",
    "region": "ResourceLocation",
    "service_name": "ServiceName",
    "service_family": "ServiceFamily",
    "product": "Product",
    "meter": "Meter",
    "sku": "SkuName",
    "charge_type": "ChargeType",
    "pricing_model": "PricingModel",
    "quantity": "Quantity",
    "unit": "UnitOfMeasure",
    "cost": "Cost",
    "cost_usd": "CostUSD",
    "currency": "Currency"
  },
  "optimizationCostSignals": [
    "monthlyActualCost",
    "dailyCostTrend",
    "costPerResourceUnit",
    "costPerRequest",
    "costPerOperation",
    "costPerGiB",
    "costPerIOPS",
    "costPerThroughputUnit",
    "reservationCoveragePct",
    "savingsPlanCoveragePct",
    "unusedReservationCost",
    "unusedSavingsPlanCost",
    "orphanedResourceCost",
    "idleResourceCost",
    "premiumFeatureCost",
    "backupStorageCost",
    "networkEgressCost",
    "transactionCost"
  ],
  "retailPriceUse": {
    "purpose": "Retail Prices API is for target comparison and estimates only. Actual current cost should come from Cost Management.",
    "joinHints": [
      "armRegionName == normalized region",
      "serviceName/serviceFamily match service",
      "armSkuName or skuName match resource SKU where available",
      "meterName/ProductName match target meter",
      "priceType in Consumption, Reservation"
    ]
  }
}
