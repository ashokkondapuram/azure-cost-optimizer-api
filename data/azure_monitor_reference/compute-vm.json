  "profile_metrics": [
    {
      "rest_api_name": "Percentage CPU",
      "fact_key": "avg_cpu_pct",
      "rules": [
        "VM_IDLE",
        "VM_OVERSIZE"
      ]
    },
    {
      "rest_api_name": "Available Memory Bytes",
      "fact_key": "avg_available_memory_bytes",
      "rules": [
        "VM_OVERSIZE",
        "VM_MEMORY_PRESSURE_EXTENDED"
      ]
    },
    {
      "rest_api_name": "Network Out Total",
      "fact_key": "network_out_bytes",
      "aggregation": "Total",
      "rules": [
        "VM_EGRESS_HIGH_EXTENDED",
        "VM_NETWORK_BOTTLENECK"
      ]
    },
    {
      "rest_api_name": "OS Disk Queue Depth",
      "fact_key": "disk_queue_depth",
      "rules": [
        "VM_DISK_BOTTLENECK"
      ]
    }
  ],
  "recommended_profile_additions": [
    {
      "rest_api_name": "OS Disk IOPS Consumed Percentage",
      "fact_key": "os_disk_iops_consumed_pct",
      "rules": [
