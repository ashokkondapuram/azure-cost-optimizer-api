{
  "schema_version": 1,
  "service": "Azure Application Gateway",
  "documentation": {
    "overview": "https://learn.microsoft.com/en-us/azure/application-gateway/overview",
    "metrics": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-network-applicationgateways-metrics",
    "pricing": "https://azure.microsoft.com/en-us/pricing/details/application-gateway/"
  },
  "sku_tiers": {
    "Standard_v2": {
      "fixed_cost_hourly_usd": 0.246,
      "capacity_unit_hourly_usd": 0.0144,
      "cu_per_capacity_unit": 100
    },
    "WAF_v2": {
      "fixed_cost_hourly_usd": 0.443,
      "capacity_unit_hourly_usd": 0.0144,
      "cu_per_capacity_unit": 100
    }
  },
  "pricing": {
    "regional_multiplier_min": 1.0,
    "regional_multiplier_max": 1.625
  },
  "optimization_thresholds": {
    "cu_saturation_pct": 80.0,
    "cu_downsize_pct": 30.0,
    "idle_throughput_bytes": 500.0,
    "idle_request_count": 100.0,
    "evaluation_window_days": 7,
    "min_monthly_savings_usd": 25.0
  },
  "analysis_rules": {
    "APPGW_UNUSED": {
      "required_evidence": [
        {
          "signal": "throughput_bytes",
          "label": "Throughput",
          "aggregation": "avg",
          "period": "7d",
          "unit": "bytes",
          "pillar": "performance"
        },
        {
          "signal": "request_count",
          "label": "Request count",
          "aggregation": "sum",
          "period": "7d",
          "unit": "requests",
          "threshold_key": "app_idle_request_threshold",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "APP_GATEWAY_IDLE_EXTENDED": {
      "required_evidence": [
        {
          "signal": "throughput_bytes",
          "label": "Throughput",
          "aggregation": "avg",
          "period": "7d",
          "unit": "bytes",
          "pillar": "performance"
        },
        {
          "signal": "request_count",
          "label": "Request count",
          "aggregation": "sum",
          "period": "7d",
          "unit": "requests",
          "threshold_key": "app_idle_request_threshold",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "APP_GATEWAY_CU_SATURATION": {
      "required_evidence": [
        {
          "signal": "capacity_unit_utilization_pct",
          "label": "Capacity unit utilization",
          "aggregation": "avg",
          "period": "7d",
          "unit": "%",
          "threshold_key": "app_gateway_cu_saturation_pct",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "APP_GATEWAY_CU_RIGHTSIZE_DOWN": {
      "required_evidence": [
        {
          "signal": "capacity_unit_utilization_pct",
          "label": "Capacity unit utilization",
          "aggregation": "avg",
          "period": "7d",
          "unit": "%",
          "threshold_key": "app_gateway_cu_saturation_pct",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    }
  }
}
