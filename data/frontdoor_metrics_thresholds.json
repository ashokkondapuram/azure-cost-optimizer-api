{
  "schema_version": 1,
  "service": "Azure Front Door",
  "documentation": {
    "overview": "https://learn.microsoft.com/en-us/azure/frontdoor/",
    "pricing": "https://azure.microsoft.com/en-us/pricing/details/frontdoor/"
  },
  "optimization_thresholds": {
    "min_monthly_cost_usd": 80,
    "request_count_low": 5000,
    "savings_factor": 0.2,
    "evaluation_window_days": 30,
    "min_monthly_savings_usd": 5
  },
  "analysis_rules": {
    "NETWORK_FRONT_DOOR_REVIEW": {
      "required_evidence": [],
      "exclude_inventory_facts": true
    },
    "NETWORK_FRONT_DOOR_IDLE_EXTENDED": {
      "required_evidence": [
        {
          "signal": "request_count",
          "label": "Request count",
          "aggregation": "sum",
          "period": "7d",
          "unit": "requests",
          "threshold_key": "app_idle_request_threshold",
          "pillar": "performance"
        },
        {
          "signal": "network_bytes",
          "label": "Bytes transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "bytes",
          "threshold_key": "idle_byte_threshold",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "NETWORK_FRONT_DOOR_COST_EXTENDED": {
      "required_evidence": [
        {
          "signal": "monthly_cost_usd",
          "label": "Month-to-date cost",
          "aggregation": "sum",
          "period": "MTD",
          "unit": "USD",
          "threshold_key": "min_monthly_savings_usd",
          "pillar": "cost"
        },
        {
          "signal": "request_count",
          "label": "Request count",
          "aggregation": "sum",
          "period": "7d",
          "unit": "requests",
          "threshold_key": "app_idle_request_threshold",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    }
  }
}
