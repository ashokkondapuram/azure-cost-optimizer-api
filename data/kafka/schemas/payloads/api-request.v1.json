{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://costoptimizer.zafin.com/schemas/kafka/payloads/api-request.v1.json",
  "title": "ApiThrottleRequestPayload",
  "description": "Payload for api.*.requested and api.*.completed throttle topics.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "batch_id": { "type": "string" },
    "phase": { "type": "string" },
    "phase_index": { "type": "integer" },
    "total_phases": { "type": "integer" },
    "api_params": { "type": "object", "additionalProperties": true },
    "run_params": { "type": "object", "additionalProperties": true },
    "meta": { "type": "object", "additionalProperties": true },
    "result": { "type": ["object", "array", "null"] },
    "api_kind": { "type": "string" },
    "error": { "type": "string" },
    "original_topic": { "type": "string" },
    "original_job_type": { "type": "string" },
    "original_job_id": { "type": "string" }
  }
}
