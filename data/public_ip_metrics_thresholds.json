{
  "schema_version": 1,
  "service": "Azure Public IP addresses",
  "basic_sku_retirement": "2025-09-30",
  "documentation": {
    "overview": "https://learn.microsoft.com/en-us/azure/virtual-network/ip-services/public-ip-addresses",
    "metrics": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-network-publicipaddresses-metrics",
    "basic_retirement": "https://learn.microsoft.com/en-us/azure/virtual-network/ip-services/public-ip-basic-upgrade-guidance"
  },
  "skus": {
    "Basic": {
      "retiring": true,
      "migrate_to": "Standard",
      "zone_redundant": false
    },
    "Standard": {
      "retiring": false,
      "zone_redundant": true
    },
    "Standard_v2": {
      "retiring": false,
      "zone_redundant": true,
      "ipv6": true
    }
  },
  "pricing": {
    "hourly_usd_baseline": 0.004,
    "regional_multiplier_min": 1.0,
    "regional_multiplier_max": 1.625
  },
  "optimization_thresholds": {
    "idle_byte_threshold": 100,
    "idle_packet_threshold": 100,
    "evaluation_window_days": 7,
    "min_monthly_savings_usd": 2.0
  },
  "analysis_rules": {
    "IP_UNASSOCIATED": {
      "required_evidence": [
        {
          "signal": "network_bytes",
          "label": "Bytes transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "bytes",
          "threshold_key": "idle_byte_threshold",
          "pillar": "performance"
        },
        {
          "signal": "packet_count",
          "label": "Packets transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "packets",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "PUBLIC_IP_IDLE_EXTENDED": {
      "required_evidence": [
        {
          "signal": "network_bytes",
          "label": "Bytes transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "bytes",
          "threshold_key": "idle_byte_threshold",
          "pillar": "performance"
        },
        {
          "signal": "packet_count",
          "label": "Packets transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "packets",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "PUBLIC_IP_BASIC_SKU_MIGRATION": {
      "required_evidence": [],
      "exclude_inventory_facts": true
    }
  }
}
