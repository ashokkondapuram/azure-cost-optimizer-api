{
  "schema_version": 1,
  "service": "Azure Database for PostgreSQL Flexible Server",
  "documentation": {
    "overview": "https://learn.microsoft.com/en-us/azure/postgresql/overview",
    "compute_storage": "https://learn.microsoft.com/en-us/azure/postgresql/flexible-server/concepts-compute-storage",
    "high_availability": "https://learn.microsoft.com/en-us/azure/postgresql/flexible-server/concepts-high-availability",
    "metrics": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-dbforpostgresql-flexibleservers-metrics"
  },
  "tiers": {
    "Burstable": {
      "tier_keys": ["burstable", "b"],
      "sku_prefixes": ["standard_b"],
      "vcores_min": 1,
      "vcores_max": 20,
      "memory_gib_per_vcpu": 2,
      "max_connections": 5000,
      "recommended_for": ["Dev/test", "Non-critical workloads"],
      "avoid_for": ["Production", "Sustained high CPU"],
      "upgrade_paths": ["GeneralPurpose"],
      "downgrade_paths": []
    },
    "GeneralPurpose": {
      "tier_keys": ["generalpurpose", "gp"],
      "sku_prefixes": ["standard_d"],
      "vcores_min": 2,
      "vcores_max": 96,
      "memory_gib_per_vcpu": 4,
      "max_connections": 5000,
      "recommended_for": ["Most production workloads"],
      "avoid_for": ["Memory-bound workloads needing >4 GiB/vCore"],
      "upgrade_paths": ["MemoryOptimized"],
      "downgrade_paths": ["Burstable"]
    },
    "MemoryOptimized": {
      "tier_keys": ["memoryoptimized", "mo"],
      "sku_prefixes": ["standard_e"],
      "vcores_min": 2,
      "vcores_max": 192,
      "memory_gib_per_vcpu": 8,
      "max_connections": 5000,
      "recommended_for": ["Memory-intensive production workloads"],
      "avoid_for": ["Dev/test", "Low memory utilization"],
      "upgrade_paths": [],
      "downgrade_paths": ["GeneralPurpose"]
    }
  },
  "storage": {
    "min_gb": 32,
    "max_gb": 16384,
    "auto_grow_supported": true
  },
  "ha_modes": {
    "Disabled": {"cost_multiplier": 1.0, "description": "No standby replica"},
    "SameZone": {"cost_multiplier": 1.5, "description": "Standby in same zone (+50% compute)"},
    "ZoneRedundant": {"cost_multiplier": 2.0, "description": "Zone-redundant standby (+100% compute)"}
  },
  "optimization_thresholds": {
    "cpu_high_pct": 80,
    "cpu_low_pct": 25,
    "memory_pressure_pct": 85,
    "memory_low_pct": 40,
    "storage_high_pct": 80,
    "storage_low_pct": 40,
    "storage_overprovision_gb": 256,
    "iops_pressure_pct": 80,
    "connection_risk_pct": 70,
    "connection_risk_absolute": 3500,
    "replication_lag_seconds": 5,
    "backup_retention_prod_days": 14,
    "backup_retention_dev_days": 7,
    "version_lag_major_releases": 2,
    "min_downgrade_savings_pct": 30
  },
  "supported_major_versions": [11, 12, 13, 14, 15, 16, 17]
}
