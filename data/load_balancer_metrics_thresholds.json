{
  "schema_version": 1,
  "service": "Azure Load Balancer",
  "basic_sku_retirement": "2025-09-30",
  "documentation": {
    "overview": "https://learn.microsoft.com/en-us/azure/load-balancer/load-balancer-overview",
    "metrics": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-network-loadbalancers-metrics"
  },
  "skus": {
    "Basic": {
      "retiring": true,
      "migrate_to": "Standard"
    },
    "Standard": {
      "retiring": false
    }
  },
  "pricing": {
    "hourly_usd_baseline": 0.025,
    "data_processing_usd_per_gb_baseline": 0.005
  },
  "optimization_thresholds": {
    "snat_pressure_pct": 70.0,
    "throughput_low_pct_of_peak": 10.0,
    "idle_byte_threshold": 1000000.0,
    "backend_availability_low_pct": 50.0,
    "min_monthly_savings_usd": 5.0
  },
  "analysis_rules": {
    "LB_NO_BACKEND": {
      "required_evidence": [
        {
          "signal": "network_bytes",
          "label": "Bytes transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "bytes",
          "threshold_key": "idle_byte_threshold",
          "pillar": "performance"
        },
        {
          "signal": "backend_health_pct",
          "label": "Backend health",
          "aggregation": "avg",
          "period": "7d",
          "unit": "%",
          "threshold_key": "backend_availability_low_pct",
          "pillar": "reliability"
        }
      ],
      "exclude_inventory_facts": true
    },
    "LOAD_BALANCER_IDLE_EXTENDED": {
      "required_evidence": [
        {
          "signal": "network_bytes",
          "label": "Bytes transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "bytes",
          "threshold_key": "idle_byte_threshold",
          "pillar": "performance"
        },
        {
          "signal": "backend_health_pct",
          "label": "Backend health",
          "aggregation": "avg",
          "period": "7d",
          "unit": "%",
          "threshold_key": "backend_availability_low_pct",
          "pillar": "reliability"
        }
      ],
      "exclude_inventory_facts": true
    },
    "LOAD_BALANCER_SNAT_PRESSURE": {
      "required_evidence": [
        {
          "signal": "snat_port_utilization_pct",
          "label": "SNAT port utilization",
          "aggregation": "peak",
          "period": "7d",
          "unit": "%",
          "threshold_key": "lb_snat_pressure_pct",
          "pillar": "reliability"
        }
      ],
      "exclude_inventory_facts": true
    },
    "LOAD_BALANCER_THROUGHPUT_RIGHTSIZE": {
      "required_evidence": [
        {
          "signal": "network_bytes",
          "label": "Bytes transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "bytes",
          "threshold_key": "idle_byte_threshold",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "LOAD_BALANCER_BACKEND_CONSOLIDATION": {
      "required_evidence": [
        {
          "signal": "network_bytes",
          "label": "Bytes transmitted",
          "aggregation": "sum",
          "period": "7d",
          "unit": "bytes",
          "threshold_key": "idle_byte_threshold",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
    },
    "LOAD_BALANCER_BASIC_SKU_MIGRATION": {
      "required_evidence": [],
      "exclude_inventory_facts": true
    }
  }
}
