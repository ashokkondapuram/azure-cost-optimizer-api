  "analysis_rules": {
    "SQL_IDLE": {
      "required_evidence": [
        {
          "signal": "dtu_utilization_pct",
          "label": "DTU utilization",
          "aggregation": "avg",
          "period": "7d",
          "unit": "%",
          "threshold_key": "db_dtu_idle_pct",
          "pillar": "performance"
        }
      ],
      "exclude_inventory_facts": true
