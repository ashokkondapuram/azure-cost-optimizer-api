  "service_overrides": {
    "Microsoft.ServiceBus/namespaces": {
      "recommended_region": "canadacentral",
      "secondary_region": "canadaeast",
      "region_move_allowed": false,
      "migration_required": true,
      "migration_notes": "Service Bus namespaces cannot change region in place. Plan a new namespace in the approved region, migrate queues/topics/subscriptions, update connection strings, and decommission the old namespace.",
      "available_regions_note": "Service Bus is available in all Azure public regions; organizational approval limits deployment to Canada Central and Canada East."
    },
    "Microsoft.ServiceBus/namespaces/queues": {
      "recommended_region": "canadacentral",
      "region_move_allowed": false,
      "inherits_namespace_region": true
    },
    "Microsoft.ServiceBus/namespaces/topics": {
      "recommended_region": "canadacentral",
      "region_move_allowed": false,
      "inherits_namespace_region": true
    },
    "Microsoft.Compute/disks": {
      "recommended_region": "canadacentral",
      "secondary_region": "canadaeast",
      "region_move_allowed": false,
      "migration_required": true,
      "migration_notes": "Managed disks cannot change region in place. Snapshot the disk, copy to Canada Central, and attach to a VM in that region."
    }
  },
  "signal_mapping": {
    "regionApproved": "resource.location is in classifications.approved.regions",
    "regionClassification": "approved | conditional | blocked | unclassified",
    "recommendedRegion": "primary_approved_region or service_overrides.recommended_region",
    "regionMoveAllowed": "service_overrides.region_move_allowed (default false for immovable services)",
    "currentRegion": "resource.location normalized"
  }
