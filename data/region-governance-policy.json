{
  "schema_version": 1,
  "policy_name": "Zafin Canada data residency",
  "description": "Organizational region approval for production workloads. Unlisted regions are unclassified and flagged for review.",
  "primary_approved_region": "canadacentral",
  "secondary_approved_region": "canadaeast",
  "data_residency_boundary": "Canada",
  "classifications": {
    "approved": {
      "regions": [
        "canadacentral",
        "canadaeast"
      ],
      "use_for": [
        "production",
        "non_production"
      ],
      "data_residency": "Canada"
    },
    "conditional": {
      "regions": [],
      "requires_approval": true,
      "use_for": [
        "non_production"
      ]
    },
    "blocked": {
      "regions": [],
      "reason": "Explicitly blocked by organizational policy"
    }
  },
  "recommended_target": {
    "production": "canadacentral",
    "non_production": "canadacentral",
    "disaster_recovery": "canadaeast"
  },
  "azure_region_catalog": {
    "canadacentral": {
      "display_name": "Canada Central",
      "geography": "Canada",
      "paired_region": "canadaeast",
      "availability_zones": true
    },
    "canadaeast": {
      "display_name": "Canada East",
      "geography": "Canada",
      "paired_region": "canadacentral",
      "availability_zones": false
    },
    "eastus": {
      "display_name": "East US",
      "geography": "United States",
      "paired_region": "westus",
      "availability_zones": true
    },
    "eastus2": {
      "display_name": "East US 2",
      "geography": "United States",
      "paired_region": "centralus",
      "availability_zones": true
    },
    "westus2": {
      "display_name": "West US 2",
      "geography": "United States",
      "paired_region": "westcentralus",
      "availability_zones": true
    },
    "centralus": {
      "display_name": "Central US",
      "geography": "United States",
      "paired_region": "eastus2",
      "availability_zones": true
    },
    "northeurope": {
      "display_name": "North Europe",
      "geography": "Europe",
      "paired_region": "westeurope",
      "availability_zones": true
    },
    "westeurope": {
      "display_name": "West Europe",
