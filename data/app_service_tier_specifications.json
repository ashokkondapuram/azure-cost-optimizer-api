{
  "schema_version": 1,
  "service": "Azure App Service (Web/Function Apps)",
  "documentation": {
    "overview": "https://learn.microsoft.com/en-us/azure/app-service/",
    "metrics": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-web-sites-metrics",
    "pricing": "https://azure.microsoft.com/en-us/pricing/details/app-service/linux/"
  },
  "tiers": {
    "Free": { "monthly_usd_min": 0, "instances": 1, "autoscale": false },
    "Shared": { "monthly_usd_min": 0, "instances": 1, "autoscale": false },
    "Basic": { "monthly_usd_min": 5, "instances": 3, "autoscale": false },
    "Standard": { "monthly_usd_min": 10, "instances": 10, "autoscale": true },
    "Premium": { "monthly_usd_min": 200, "instances": 30, "autoscale": true }
  },
  "optimization_thresholds": {
    "plan_load_low_pct": 20.0,
    "memory_pressure_pct": 80.0,
    "cpu_quota_high_pct": 80.0,
    "response_time_ms_peak": 500.0,
    "http_5xx_rate_pct": 5.0,
    "idle_requests_per_day": 1.0,
    "evaluation_window_days": 30,
    "min_monthly_savings_usd": 5.0
  }
}
