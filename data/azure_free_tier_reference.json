  "account_programs": {
    "30_days_credit": {
      "duration": "30_days_new_account",
      "limit": "USD 200 credit for first 30 days",
      "notes": "Applies to services outside free allowances; account disabled if not upgraded.",
      "doc_ref": "https://azure.microsoft.com/pricing/purchase-options/azure-account"
    },
    "12_months_popular": {
      "duration": "12_months_new_account",
      "limit": "Monthly free amounts of popular services for 12 months after account creation",
      "notes": "Requires pay-as-you-go upgrade within 30 days or after credit is used.",
      "doc_ref": "https://azure.microsoft.com/pricing/free-services"
    },
    "always_free_monthly": {
      "duration": "always",
      "limit": "65+ services with recurring monthly free amounts",
      "notes": "Continues on pay-as-you-go after free-account period; overages bill at meter rates.",
      "doc_ref": "https://azure.microsoft.com/pricing/free-services"
    }
  },
  "twelve_month_services": {
    "Virtual Machines": {
      "limit": "750 hours each of B2pts v2 (Arm-based) and B2ats v2 (AMD-based) burstable VMs per month",
      "notes": "12 months from Azure account creation for eligible new customers.",
      "doc_ref": "https://azure.microsoft.com/en-us/pricing/free-services/#List-of-free-services"
    },
    "Storage": {
      "limit": "5 GB LRS Blob hot block, 100 GB Azure Files, 10 GB Archive, and 2×64 GB managed disks per month",
      "notes": "12-month new-account allowances per official free services list.",
      "doc_ref": "https://azure.microsoft.com/en-us/pricing/free-services/#List-of-free-services"
    },
    "SQL Managed Instance": {
      "limit": "720 vCore hours of 4-vCore or 8-vCore General Purpose with 64 GB data and backup storage",
      "notes": "12-month new-account allowance."
    },
    "Load Balancer": {
      "limit": "750 hours Standard Load Balancer + 15 GB data processed + up to 5 rules",
      "notes": "12-month new-account allowance; Basic SKU has no hourly charge always.",
      "doc_ref": "https://azure.microsoft.com/en-us/products/load-balancer/"
    },
    "Bandwidth": {
      "limit": "15 GB outbound data transfer per month (plus 100 GB always-free allowance)",
      "notes": "New-account 12-month allowance is additive to always-free 100 GB outbound.",
      "doc_ref": "https://azure.microsoft.com/en-us/pricing/free-services/#List-of-free-services"
