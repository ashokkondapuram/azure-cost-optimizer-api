    "Key Vault": {
      "limit": "10,000 transactions RSA 2048-bit keys or secret operations, Standard tier",
      "notes": "12-month new-account allowance per official free services page.",
      "doc_ref": "https://azure.microsoft.com/en-us/products/key-vault/"
    },
    "Service Bus": {
      "limit": "750 hours and 13 million operations Standard tier base unit",
      "notes": "12-month new-account allowance.",
      "doc_ref": "https://azure.microsoft.com/en-us/products/service-bus/"
