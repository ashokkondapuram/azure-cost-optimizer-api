{
  "schema_version": 1,
  "service": "Azure Cache for Redis",
  "retirement_date": "2028-09-30",
  "migration_target": "Azure Managed Redis",
  "documentation": {
    "overview": "https://learn.microsoft.com/en-us/azure/azure-cache-for-redis/cache-overview",
    "metrics": "https://learn.microsoft.com/en-us/azure/azure-monitor/reference/supported-metrics/microsoft-cache-redis-metrics",
    "retirement": "https://learn.microsoft.com/en-us/azure/azure-cache-for-redis/retirement-faq"
  },
  "tiers": {
    "Basic": {
      "family_codes": ["C"],
      "memory_mb_min": 250,
      "memory_mb_max": 53248,
      "replication": false,
      "sla_uptime": null,
      "clustering": false,
      "max_shards": 1,
      "persistence": false,
      "geo_replication": false,
      "zone_redundancy": false,
      "redis_modules": false,
      "recommended_for": ["Dev/test", "Non-critical caches"],
      "avoid_for": ["Production HA", "Persistence", "Geo-replication"],
      "upgrade_paths": ["Standard", "Premium"],
      "downgrade_paths": []
    },
    "Standard": {
      "family_codes": ["C"],
      "memory_mb_min": 250,
      "memory_mb_max": 53248,
      "replication": true,
      "replica_count": 1,
      "sla_uptime": 99.9,
      "clustering": false,
      "max_shards": 1,
      "persistence": false,
      "geo_replication": false,
      "zone_redundancy": true,
      "redis_modules": false,
      "recommended_for": ["Production workloads without persistence"],
      "avoid_for": ["Large datasets requiring clustering", "RDB/AOF persistence"],
      "upgrade_paths": ["Premium", "Enterprise"],
      "downgrade_paths": ["Basic"]
    },
    "Premium": {
      "family_codes": ["P"],
      "memory_mb_min": 6144,
      "memory_mb_max": 1228800,
      "replication": true,
      "replica_count": 1,
      "sla_uptime": 99.9,
      "clustering": true,
      "max_shards": 10,
      "persistence": true,
      "persistence_options": ["RDB", "AOF"],
      "geo_replication": "passive",
      "zone_redundancy": true,
      "redis_modules": false,
      "recommended_for": ["Production with persistence", "High throughput via clustering"],
      "avoid_for": ["Redis modules", "Active geo-replication"],
      "upgrade_paths": ["Enterprise"],
      "downgrade_paths": ["Standard"]
    },
    "Enterprise": {
      "family_codes": ["E"],
      "memory_mb_min": 1024,
      "memory_mb_max": 2097152,
      "replication": true,
      "replica_count": 2,
      "sla_uptime": 99.95,
      "clustering": true,
      "max_shards": 15,
      "persistence": true,
      "persistence_options": ["RDB", "AOF"],
      "geo_replication": "active",
      "zone_redundancy": true,
      "redis_modules": true,
      "recommended_for": ["Redis modules", "Active geo-replication", "Large memory"],
      "avoid_for": ["Simple dev/test caches"],
      "upgrade_paths": ["EnterpriseFlash"],
      "downgrade_paths": ["Premium"]
    },
    "EnterpriseFlash": {
      "family_codes": ["F"],
      "memory_mb_min": 307200,
      "memory_mb_max": 4608000,
      "replication": true,
      "replica_count": 2,
      "sla_uptime": 99.95,
      "clustering": true,
      "max_shards": 15,
      "persistence": true,
      "persistence_options": ["RDB", "AOF"],
      "geo_replication": "active",
      "zone_redundancy": true,
      "redis_modules": true,
      "recommended_for": ["Very large datasets with flash-backed memory"],
      "avoid_for": ["Small workloads"],
      "upgrade_paths": [],
      "downgrade_paths": ["Enterprise"]
    }
  },
  "capacity_units": {
    "C0": {"memory_mb": 250, "max_connections": 256},
    "C1": {"memory_mb": 1024, "max_connections": 1000},
    "C2": {"memory_mb": 2560, "max_connections": 2000},
    "C3": {"memory_mb": 6144, "max_connections": 5000},
    "C4": {"memory_mb": 13312, "max_connections": 10000},
    "C5": {"memory_mb": 26624, "max_connections": 15000},
    "C6": {"memory_mb": 53248, "max_connections": 20000},
    "P1": {"memory_mb": 6144, "max_connections": 7500},
    "P2": {"memory_mb": 13312, "max_connections": 15000},
    "P3": {"memory_mb": 26624, "max_connections": 30000},
    "P4": {"memory_mb": 53248, "max_connections": 40000},
    "P5": {"memory_mb": 122880, "max_connections": 50000}
  },
  "optimization_thresholds": {
    "memory_pressure_pct": 85,
    "redis_memory_pressure_pct": 85,
    "memory_low_utilization_pct": 30,
    "redis_low_utilization_pct": 30,
    "server_load_low_pct": 20,
    "redis_server_load_low_pct": 20,
    "hit_ratio_poor_pct": 50,
    "redis_hit_ratio_poor_pct": 50,
    "hit_ratio_healthy_pct": 80,
    "cluster_unnecessary_ops_per_sec": 50000,
    "redis_cluster_ops_threshold": 50000,
    "idle_ops_per_sec": 0,
    "redis_idle_ops_threshold": 0,
    "rightsizing_headroom_pct": 25,
    "upgrade_urgent_memory_pct": 90,
    "redis_premium_min_capacity": 6
  },
  "metric_guidance": {
    "usedmemorypercentage": {"unit": "%", "upgrade_at": 85, "downgrade_below": 30},
    "cachehitrate": {"unit": "%", "healthy_above": 80, "poor_below": 50, "note": "Derived from cachehits/cachemisses or cachemissrate"},
    "cachemissrate": {"unit": "%", "poor_above": 50},
    "operationsPerSecond": {"unit": "ops/sec", "cluster_review_below": 50000},
    "serverLoad": {"unit": "%", "bottleneck_above": 80, "low_below": 20},
    "evictedkeys": {"unit": "count", "action": "upgrade_if_nonzero"},
    "connectedclients": {"unit": "count", "action": "compare_to_tier_max"},
    "replicationlag": {"unit": "seconds", "alert_above": 5}
  }
}
